generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  USER
}

model User {
  id    String @id @default(uuid())
  name  String
  email         String   @unique
  password_hash String

  dishes Dish[]

  createdAt DateTime @default(now())
}

model Dish {
  id          String  @id @default(uuid())
  title       String
  description String
  price       Float

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade) // o cascade e para deletar todos que estiver relacionando a o user caso o user for deletado.

  createdAt DateTime @default(now())
}
